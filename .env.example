# Copiar este archivo a .env y completar los valores
# .env nunca debe subirse al repositorio (ver .gitignore)

# Clave secreta de Django. Generar una nueva en produccion.
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=django-insecure-cambia-esta-clave-en-produccion

# Modo debug. Debe ser False en produccion.
DJANGO_DEBUG=True

# Hosts permitidos separados por coma (ej: localhost,127.0.0.1,midominio.cl)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1